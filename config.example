# herdr-quicklook configuration (all optional).
# Copy this file as `.env` into the directory printed by:
#   herdr plugin config-dir herdr-quicklook
# Without a .env the plugin works with defaults; every setting here is optional.

# QUICKLOOK_ROOTS: extra directories to try when a copied path does not exist
# under the current pane directory or repo. Colon-separated.
#
# The problem it solves: an agent prints `myrepo/docs/notes.md` but you are
# standing in a different repo. If all your repos live under ~/workspace,
# adding it here lets that path resolve to ~/workspace/myrepo/docs/notes.md.
#QUICKLOOK_ROOTS="$HOME/workspace:$HOME/src"

# QUICKLOOK_EDITOR: command launched by `e` in the preview overlay, at the
# current file+line. Precedence: this key > $EDITOR > "zed --wait". Set this
# instead of (or in addition to) exporting $EDITOR in your shell: the herdr
# server process that launches this pane does not reliably inherit your
# interactive shell's exported vars, so a config value here is the reliable
# path (the same reason QUICKLOOK_ROOTS lives here instead of relying on env).
#QUICKLOOK_EDITOR="zed --wait"

# QUICKLOOK_AGENT_SUGGESTIONS: react to herdr's agent-status event without a
# polling daemon. "notify" stores the best token produced during the latest
# turn and shows a herdr notification; "preview" also opens it immediately.
# Defaults to "off" because immediate previews can interrupt another pane.
# It uses the same Bash 3.2-compatible scanner as `pick` and `linkify`.
#QUICKLOOK_AGENT_SUGGESTIONS="notify"

# QUICKLOOK_AGENT_SCAN_LINES: recent-unwrapped lines retained for the working
# baseline and completion diff. Invalid values fall back to 300.
#QUICKLOOK_AGENT_SCAN_LINES=300

# Hint picker: re-enable bare-word fuzzy filename hints (noisy, off by default).
#QUICKLOOK_HINT_NAMES=1

# Hint picker: restore the slower fully-verified scan instead of shape-first.
#QUICKLOOK_HINT_VERIFIED=1
